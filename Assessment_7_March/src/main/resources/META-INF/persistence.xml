<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence" version="2.2">
    <persistence-unit name="my-pu" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <properties>
            <property name="javax.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="javax.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/dept_emp"/>
            <property name="javax.persistence.jdbc.user" value="root"/>
            <property name="javax.persistence.jdbc.password" value="Sk@24sql"/>
<!--            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL8Dialect"/>-->
<!--            MySQL8Dialect - act as an interpreter , make jav code vendor independent,don't need to change java code-->
            <property name="hibernate.hbm2ddl.auto" value="update"/>
<!--            create table if not created -->
            <property name="hibernate.show_sql" value="true"/>
<!--            above line show sql query on console-->

        </properties>
    </persistence-unit>
</persistence>